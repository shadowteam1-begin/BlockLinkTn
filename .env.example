# ═══════════════════════════════════════════
# BloodLink TN — Environment Variables
# STEP 1: Copy this file, rename to .env
# STEP 2: Fill in your real values below
# NEVER commit .env to GitHub!
# ═══════════════════════════════════════════

# ── MongoDB ──────────────────────────────
# Get this from MongoDB Atlas (Step 5 guide)
# Format: mongodb+srv://username:password@cluster.mongodb.net/bloodlink
MONGO_URI=mongodb://blood_01:Arif_2627@ac-hbm6pbg-shard-00-00.9g8bd3g.mongodb.net:27017,ac-hbm6pbg-shard-00-01.9g8bd3g.mongodb.net:27017,ac-hbm6pbg-shard-00-02.9g8bd3g.mongodb.net:27017/?ssl=true&replicaSet=atlas-rshn53-shard-0&authSource=admin&appName=Cluster0
JWT_SECRET=bloodlink_tn_super_secure_jwt_key_2024_never_share

# ── JWT Secret ───────────────────────────
# Make this a long random string (32+ chars)
# You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=replace_this_with_a_long_random_secret_string_32chars

# JWT expiry (how long login tokens last)
JWT_EXPIRES_IN=7d

# ── Server ───────────────────────────────
PORT=5000

# ── CORS (your frontend URL) ─────────────
# In development: http://localhost:5500 (Live Server)
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5500

# ── Socket.io ────────────────────────────
SOCKET_CORS_ORIGIN=http://localhost:5500

# ── MSG91 SMS (Step 7 — leave blank for now) ──
MSG91_AUTH_KEY=
MSG91_SENDER_ID=BLDLNK
MSG91_TEMPLATE_ID=
